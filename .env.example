# v2b_syndata environment template.
# Copy to .env and fill in values:
#     cp .env.example .env
# .env is gitignored — never commit secrets.

# ACN-Data API token. Required only for `v2b-syndata calibrate` runs that
# fetch sessions from https://ev.caltech.edu/api/v1/sessions/. Cache hits
# in data/calibration/acn_cache/ bypass this token entirely.
#
# Request access: https://ev.caltech.edu/dataset
ACN_API_TOKEN=your_token_here
