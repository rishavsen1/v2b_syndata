  "@type": "sc:Dataset",
  "conformsTo": "http://mlcommons.org/croissant/1.0",
  "name": "v2b_syndata",
  "description": "Configurable synthetic Vehicle-to-Building (V2B) EV-charging dataset GENERATOR. A (scenario YAML, knob overrides, seed) triple forward-samples bitwise-identical CSVs: EV users, cars, chargers, charging sessions, EnergyPlus building load, rooftop PV, stationary battery specs, grid tariffs, and demand-response events. Behavioral distributions are calibrated from public ACN-Data, ElaadNL, and EV WATTS charging logs; state-of-charge is modeled from a prior (never observed). This record describes one generated dataset instance (one scenario-seed output directory). A frozen 18,000-unit reference corpus (10 buildings x 12 months x 150 seeded samples, ~19 GiB) is released alongside the generator (see docs/experiments/DEPOSIT_PLAN.md). See docs/DATASHEET.md, docs/ETHICS.md, docs/CALIBRATION_RESULTS.md.",
  "version": "0.1.0",
  "isLiveDataset": true,
  "datePublished": "2026-06-29",
  "keywords": [
    "synthetic data",
    "electric vehicles",
    "EV charging",
    "vehicle-to-building",
    "V2B",
    "building energy",
    "EnergyPlus",
    "demand response",
    "load forecasting"
  ],
  "creator": {
    "@type": "sc:Organization",
    "name": "Vanderbilt University"
  },
  "publisher": {
    "@type": "sc:Organization",
    "name": "Vanderbilt University"
  },
  "license": "https://spdx.org/licenses/MIT.html",
  "url": "https://github.com/rishavsen1/v2b_syndata",
  "citeAs": "v2b_syndata: a configurable synthetic Vehicle-to-Building EV-charging dataset generator (KDD 2027 Datasets & Benchmarks submission).",
  "dataBiases": "Calibration rests on US workplace charging (ACN-Data: Caltech/JPL/Office001, plus the EV WATTS public workplace/public-L2 release under a port-as-proxy user identity) and one Netherlands network (ElaadNL); INL is a tiny synthetic fixture excluded from all fidelity numbers and released only as a labeled distribution-shift benchmark. Building load ships a single ASHRAE 90.1-2019 efficient prototype in one climate zone (Denver CZ-5B), with four of five archetypes 37-54% below the ComStock stock-weighted average intensity (large office 27% above). Not representative of residential charging, non-US/EU behavior, or older building stock. See docs/ETHICS.md.",
  "dataCollection": "Two-stage: (1) offline calibration fits per-region distribution parameters from real public charging logs (ACN-Data, ElaadNL, EV WATTS) into configs/populations.yaml, with a MIN_SAMPLES=30 floor before a region is marked calibrated; (2) generation forward-samples CSVs under a SHA-keyed RNG so a (scenario, overrides, seed) triple is bitwise-reproducible. Building load is computed with EnergyPlus at generation time (the bundled DOE prototype models are pinned to EnergyPlus 24.1). State-of-charge is never recorded in any source and is drawn from a Beta/normal prior (mean approx 0.40), not fit. See docs/GENERATIVE_MODELS.md.",
  "personalSensitiveInformation": "None. Output is fully synthetic; identifiers are sequential synthetic keys. Calibration corpora are public aggregates consumed only as distribution parameters; no raw source record is redistributed. See docs/ETHICS.md.",
  "distribution": [
    {
      "@type": "cr:FileObject",
      "@id": "users.csv",
      "name": "users.csv",
      "description": "One row per EV driver: behavioral profile (region, phi frequency, kappa consistency, delta_km commute, negotiation type, scheduler weights).",
      "contentUrl": "users.csv",
      "encodingFormat": "text/csv"
    },
    {
      "@type": "cr:FileObject",
      "@id": "cars.csv",
      "name": "cars.csv",
      "description": "One row per vehicle: battery capacity and allowed-SoC window, battery class.",
      "contentUrl": "cars.csv",
      "encodingFormat": "text/csv"
    },
    {
      "@type": "cr:FileObject",
      "@id": "chargers.csv",
      "name": "chargers.csv",
      "description": "One row per charging port: directionality and power-rate bounds (negative min_rate_kw for bidirectional).",
      "contentUrl": "chargers.csv",
      "encodingFormat": "text/csv"
    },
    {
      "@type": "cr:FileObject",
      "@id": "sessions.csv",
      "name": "sessions.csv",
      "description": "One row per charging session: arrival/departure, duration, and modeled SoC fields (arrival_soc and required_soc_at_depart are priors, not observed).",
      "contentUrl": "sessions.csv",
      "encodingFormat": "text/csv"
    },
    {
      "@type": "cr:FileObject",
      "@id": "building_load.csv",
      "name": "building_load.csv",
      "description": "15-minute building power time series from EnergyPlus: flexible, inflexible, and total kW.",
      "contentUrl": "building_load.csv",
      "encodingFormat": "text/csv"
    },
    {
      "@type": "cr:FileObject",
      "@id": "pv_generation.csv",
      "name": "pv_generation.csv",
      "description": "15-minute rooftop-PV power time series (deterministic PVWatts-style curve from the same TMYx weather as building_load; all zeros when PV disabled).",
      "contentUrl": "pv_generation.csv",
      "encodingFormat": "text/csv"
    },
    {
      "@type": "cr:FileObject",
      "@id": "pv.csv",
      "name": "pv.csv",
      "description": "Rooftop-PV system specification (capacities, orientation, derate, temperature coefficients). Off by default.",
      "contentUrl": "pv.csv",
      "encodingFormat": "text/csv"
    },
    {
      "@type": "cr:FileObject",
      "@id": "battery.csv",
      "name": "battery.csv",
      "description": "Stationary-battery specification only (capacity, power, efficiency, SoC bounds). No dispatch / SoC time series. Off by default.",
      "contentUrl": "battery.csv",
      "encodingFormat": "text/csv"
    },
    {
      "@type": "cr:FileObject",
      "@id": "grid_prices.csv",
      "name": "grid_prices.csv",
      "description": "Tariff time series: price_per_kwh and peak/off-peak label.",
      "contentUrl": "grid_prices.csv",
      "encodingFormat": "text/csv"
    },
    {
      "@type": "cr:FileObject",
      "@id": "dr_events.csv",
      "name": "dr_events.csv",
      "description": "Demand-response events (start, end, magnitude_kw, notified_at). Header-only when program=none.",
      "contentUrl": "dr_events.csv",
      "encodingFormat": "text/csv"
    },
